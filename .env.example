# ============================================
# 学生多维画像分析系统 - API Key 配置模板
# ============================================
#
# 使用说明：
#   1. 复制本文件为 .env：  cp .env.example .env
#   2. 填写你使用的提供商的 API Key
#   3. .env 已被 .gitignore 排除，不会被提交到 Git
#
# 切换提供商：修改 configs/settings.yaml 中的 llm.provider 字段
# ============================================

# --- OpenAI 官方 ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# --- DeepSeek（国内直连，推荐） ---
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# --- 智谱 GLM ---
ZHIPU_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxx

# --- Moonshot / Kimi ---
MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
